# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
APP_TITLE=Smartphone Addiction Predictor
APP_VERSION=1.0.0

# ── Model / Data paths (defaults work for local dev) ─────────────────────────
# MODEL_PATH=backend/models/addiction_model.pkl
# METRICS_PATH=backend/models/metrics.json
# DATASET_PATH=backend/data/smartphone_addiction.csv

# ── ML ────────────────────────────────────────────────────────────────────────
TEST_SIZE=0.2
RANDOM_STATE=42
CV_FOLDS=5

# ── Ollama (optional) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=30

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
